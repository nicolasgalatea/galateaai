{
  "buildCommand": "mkdir -p dist/demo && cp public/landing.html dist/index.html && cp demo/index.html dist/demo/index.html && cp public/favicon.ico dist/favicon.ico",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/agents/:agent", "destination": "/api/agents/[agent]?agent=:agent" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/demo", "destination": "/demo/index.html" },
    { "source": "/demo/(.*)", "destination": "/demo/index.html" },
    { "source": "/((?!demo|api).*)", "destination": "/index.html" }
  ]
}
