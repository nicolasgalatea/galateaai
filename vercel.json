{
  "buildCommand": "mkdir -p dist && cp demo/index.html dist/index.html",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/agents/:agent", "destination": "/api/agents/[agent]?agent=:agent" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
